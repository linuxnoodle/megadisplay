<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:clipToPadding="false"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:baselineAligned="false"
    android:minHeight="@dimen/action_preference_min_height">
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true">
        <ImageView
            android:layout_gravity="center_vertical"
            android:id="@android:id/icon"
            android:layout_width="@dimen/action_preference_icon_size"
            android:layout_height="@dimen/action_preference_icon_size"
            android:layout_marginRight="@dimen/action_preference_drawable_padding"
            android:scaleType="centerInside"
            android:contentDescription="@null"
            android:layout_marginEnd="@dimen/action_preference_drawable_padding"/>
        <TextView
            android:textColor="?attr/colorAccent"
            android:ellipsize="marquee"
            android:gravity="center"
            android:layout_gravity="center_vertical"
            android:id="@android:id/title"
            android:fadingEdge="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:singleLine="true"
            style="@style/ActionPreferenceText"/>
    </LinearLayout>
</RelativeLayout>
