<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:textAppearance="?android:attr/textAppearanceSmall"
        android:ellipsize="end"
        android:gravity="start|center_vertical"
        android:id="@+id/left_error_message"
        android:visibility="gone"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/error_message_inset_left"
        android:layout_marginTop="@dimen/error_message_inset_top"
        android:layout_marginRight="@dimen/error_message_inset_right"
        android:layout_marginBottom="@dimen/error_message_inset_bottom"
        android:maxLines="2"
        android:layout_weight="1"
        android:layout_marginStart="@dimen/error_message_inset_left"
        android:layout_marginEnd="@dimen/error_message_inset_right"/>
    <TextView
        android:textAppearance="?android:attr/textAppearanceSmall"
        android:ellipsize="end"
        android:gravity="end|center_vertical"
        android:id="@+id/right_error_message"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/error_message_inset_left"
        android:layout_marginTop="@dimen/error_message_inset_top"
        android:layout_marginRight="@dimen/error_message_inset_right"
        android:layout_marginBottom="@dimen/error_message_inset_bottom"
        android:maxLines="2"
        android:layout_marginStart="@dimen/error_message_inset_left"
        android:layout_marginEnd="@dimen/error_message_inset_right"/>
</LinearLayout>
