[Unit]
Description=MegaDisplay Daemon — USB display for Android tablets
After=graphical.target

[Service]
Type=simple
User=%i
ExecStart=/bin/sh -c 'export XDG_RUNTIME_DIR=/run/user/$$(id -u); export HYPRLAND_INSTANCE_SIGNATURE=$$(ls -t /run/user/$$(id -u)/hypr | head -n 1); exec /usr/local/bin/megadisplayd'
Restart=on-failure
RestartSec=3
Environment=RUST_LOG=info
Environment=WAYLAND_DISPLAY=wayland-1

[Install]
WantedBy=graphical.target
